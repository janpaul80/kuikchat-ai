# ============================================================================
# KuikChat — Environment Variables
# Copy this file to `.env.local` and fill in your real keys
# ============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://kuikchat.io
NEXT_PUBLIC_APP_NAME=KuikChat
NEXT_PUBLIC_APP_DOMAIN=kuikchat.io

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # SERVER ONLY — never expose to client

# ── Langdock (Hermes AI) ─────────────────────────────────────────────────────
LANGDOCK_API_KEY=ldk_...
LANGDOCK_BASE_URL=https://api.langdock.com/openai/eu/v1
LANGDOCK_CHAT_MODEL=gpt-5-chat-latest
LANGDOCK_IMAGE_MODEL=dall-e-3
LANGDOCK_TRANSCRIBE_MODEL=whisper-1

# Ecosystem Integrations (server only)
FILENINJA_API_URL=
FILENINJA_API_KEY=
REVPRO_API_URL=
REVPRO_API_KEY=

# ── Stripe (Subscriptions) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create products in Stripe Dashboard, paste IDs here)
STRIPE_PRICE_PLUS_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_HERMES_PRO_MONTHLY=price_...

# ── OAuth (configure in Supabase Auth dashboard) ─────────────────────────────
# These are configured in Supabase → Authentication → Providers, NOT here.
# But keep these notes for reference:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# LiveKit (Phase 5 — voice/video calls) ──────────────────────────
