# LIVEKIT_API_SECRET=LIVEKIT_URL=wss://kuikchat-fm5ofy3c.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# NEXT_PUBLIC_LIVEKIT_URL=
